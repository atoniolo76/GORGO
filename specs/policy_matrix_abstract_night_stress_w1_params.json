{
  "schema_version": "2.0",
  "_note": "Stress test with W1 manual starter hyperparameters (prefill_weight=0.07, load_weight=0.06). Concurrency=64. Tests hillclimb convergence from scratch under high load.",
  "run_id": "abstract_night_stress_w1params",
  "seed": null,
  "trace_path": "",
  "start_delay_seconds": 30,
  "concurrency": 64,
  "stream": true,
  "max_tokens": 128,
  "max_input_tokens": 24000,
  "arrival_mode": "open-loop",
  "time_scale": 1.0,
  "poll_interval_seconds": 60,
  "fleet_regions": [
    "ap-seoul-1",
    "eu-frankfurt-1",
    "us-ashburn-1"
  ],
  "policies": [
    {"name": "random"},
    {"name": "least-request"},
    {"name": "least-load"},
    {"name": "prefix-cache"},
    {"name": "simple-session-affinity"},
    {
      "name": "gorgo", "label": "gorgo-static",
      "hyperparameters": {"prefill_weight": 0.07, "load_weight": 0.06}
    },
    {
      "name": "gorgo", "label": "gorgo-autotune",
      "hyperparameters": {"prefill_weight": 0.07, "load_weight": 0.06},
      "auto_tune": {"enabled": true, "window_size": 64, "hop_size": 16, "apply": true, "mode": "fit"}
    },
    {
      "name": "gorgo", "label": "gorgo-hillclimb",
      "hyperparameters": {"prefill_weight": 0.07, "load_weight": 0.06},
      "auto_tune": {"enabled": true, "window_size": 64, "hop_size": 16, "apply": true, "mode": "online-es", "objective_metric": "neg_p95_ttft"}
    }
  ],
  "replica_homogeneity_check": {
    "enabled": true, "warmup_requests_per_replica": 16, "warmup_requests": 4,
    "prompt_size_tokens": 4000, "max_tokens": 16, "max_ttft_ratio": 3.0, "on_violation": "warn"
  }
}
