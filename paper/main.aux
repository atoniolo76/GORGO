\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces GLM-5.1 W1 (tuning window, 00:30--01:00 UTC). TTFT in seconds. Bold is best in column. Completed counts from proxy logs; success rate $\approx $84.2--84.6\%.}}{6}{table.caption.12}\protected@file@percent }
\newlabel{tab:w1}{{2}{6}{GLM-5.1 W1 (tuning window, 00:30--01:00 UTC). TTFT in seconds. Bold is best in column. Completed counts from proxy logs; success rate $\approx $84.2--84.6\%}{table.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Achieved prefix hit rate over the W1 tuning window: the fraction of each request's input tokens that were already cached on the replica the policy routed to (not the total cache available across all replicas). A higher rate means the routing decision exploited more of the available cache. Bold lines are EWMA-smoothed ($\alpha {=}0.06$); faint lines are 64-request rolling averages. \texttt  {gorgo-hillclimb} converges from $\sim $45\% to $\sim $95\% within the first 5 minutes as the ES learns to route requests to their best-cached replica.}}{6}{figure.caption.13}\protected@file@percent }
\newlabel{fig:cache_convergence}{{3}{6}{Achieved prefix hit rate over the W1 tuning window: the fraction of each request's input tokens that were already cached on the replica the policy routed to (not the total cache available across all replicas). A higher rate means the routing decision exploited more of the available cache. Bold lines are EWMA-smoothed ($\alpha {=}0.06$); faint lines are 64-request rolling averages. \texttt {gorgo-hillclimb} converges from $\sim $45\% to $\sim $95\% within the first 5 minutes as the ES learns to route requests to their best-cached replica}{figure.caption.13}{}}
