\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Proxy-to-replica RTT over the W1 tuning window. Bold lines show the EWMA-smoothed signal ($\alpha {=}0.3$) that GORGO uses for routing; faint lines show raw probe samples. Dashed lines show per-replica means. Seoul exhibits periodic spikes from routing-table churn; Frankfurt is moderately variable; Ashburn is near-constant. The 18$\times $ spread motivates network-aware routing.}}{5}{figure.caption.9}\protected@file@percent }
\newlabel{fig:rtt}{{2}{5}{Proxy-to-replica RTT over the W1 tuning window. Bold lines show the EWMA-smoothed signal ($\alpha {=}0.3$) that GORGO uses for routing; faint lines show raw probe samples. Dashed lines show per-replica means. Seoul exhibits periodic spikes from routing-table churn; Frankfurt is moderately variable; Ashburn is near-constant. The 18$\times $ spread motivates network-aware routing}{figure.caption.9}{}}
