\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces W1 TTFT broken out by percentile (sorted by p95, worst at top). \texttt  {gorgo-hillclimb} (gold outline) wins all three percentiles during the tuning window.}}{8}{figure.caption.17}\protected@file@percent }
\newlabel{fig:ttft_bars_w1}{{4}{8}{W1 TTFT broken out by percentile (sorted by p95, worst at top). \texttt {gorgo-hillclimb} (gold outline) wins all three percentiles during the tuning window}{figure.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textit  {Left}: KV-cache hit rate vs.\ p95 TTFT on W2. Bottom-right is ideal (high cache, low latency). \texttt  {gorgo-static} and \texttt  {gorgo-hillclimb} achieve both; \texttt  {simple-session-affinity} achieves the highest cache hit rate but the worst p95 because it cannot rebalance load. \textit  {Right}: routing concentration (share of requests on the most-used replica). The dashed line marks uniform (33\%). GORGO variants concentrate moderately on cache-warm replicas without the pathological imbalance of \texttt  {simple-session-affinity}.}}{8}{figure.caption.18}\protected@file@percent }
\newlabel{fig:cache_concentration}{{5}{8}{\textit {Left}: KV-cache hit rate vs.\ p95 TTFT on W2. Bottom-right is ideal (high cache, low latency). \texttt {gorgo-static} and \texttt {gorgo-hillclimb} achieve both; \texttt {simple-session-affinity} achieves the highest cache hit rate but the worst p95 because it cannot rebalance load. \textit {Right}: routing concentration (share of requests on the most-used replica). The dashed line marks uniform (33\%). GORGO variants concentrate moderately on cache-warm replicas without the pathological imbalance of \texttt {simple-session-affinity}}{figure.caption.18}{}}
