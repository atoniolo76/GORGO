\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Dataset comparison along axes that determine the routing-decision surface. Token counts use the same byte-pair tokenizer in all rows. Reuse percentages are token-weighted prefix-trie savings; global reuse decomposes into intra-user and cross-user components. $^*$LMSYS user count is from the dataset card \citep  {lmsys2024} (210K unique IPs across 1M conversations); the public schema does not expose the IP column, so we partition the LMSYS trie by conversation ID instead. Under that partition, intra-user reuse is 0\% as an artifact (every ``user'' has exactly one conversation), and the entire 9.0\% global reuse is attributed to cross-user; this is an upper bound on the true cross-user value, since proper IP partitioning would migrate some of it to intra-user.}}{4}{table.caption.3}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{tab:datasets}{{1}{4}{Dataset comparison along axes that determine the routing-decision surface. Token counts use the same byte-pair tokenizer in all rows. Reuse percentages are token-weighted prefix-trie savings; global reuse decomposes into intra-user and cross-user components. $^*$LMSYS user count is from the dataset card \citep {lmsys2024} (210K unique IPs across 1M conversations); the public schema does not expose the IP column, so we partition the LMSYS trie by conversation ID instead. Under that partition, intra-user reuse is 0\% as an artifact (every ``user'' has exactly one conversation), and the entire 9.0\% global reuse is attributed to cross-user; this is an upper bound on the true cross-user value, since proper IP partitioning would migrate some of it to intra-user}{table.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Three axes of dataset characterization. \textit  {Left}: average input tokens per request (log scale)---GLM-5.1 is 45$\times $ longer than LMSYS and 7$\times $ longer than WildChat. \textit  {Center}: requests per user on a log scale---82 on GLM-5.1 vs.\ 4.8 on LMSYS-Chat-1M vs.\ 1.7 on WildChat-4.8M. \textit  {Right}: prefix-reuse breakdown---GLM-5.1 reuse is dominated by intra-user repeat-conversation prefixes; WildChat reuse is dominated by cross-user structural similarity (shared system prompts, viral templates); LMSYS's intra-user component is not measurable on the public schema (no IP column), so its 9.0\% appears entirely as cross-user (an upper bound; under proper IP partitioning, some would shift to intra-user).}}{4}{figure.caption.4}\protected@file@percent }
\newlabel{fig:dataset_comparison}{{1}{4}{Three axes of dataset characterization. \textit {Left}: average input tokens per request (log scale)---GLM-5.1 is 45$\times $ longer than LMSYS and 7$\times $ longer than WildChat. \textit {Center}: requests per user on a log scale---82 on GLM-5.1 vs.\ 4.8 on LMSYS-Chat-1M vs.\ 1.7 on WildChat-4.8M. \textit {Right}: prefix-reuse breakdown---GLM-5.1 reuse is dominated by intra-user repeat-conversation prefixes; WildChat reuse is dominated by cross-user structural similarity (shared system prompts, viral templates); LMSYS's intra-user component is not measurable on the public schema (no IP column), so its 9.0\% appears entirely as cross-user (an upper bound; under proper IP partitioning, some would shift to intra-user)}{figure.caption.4}{}}
