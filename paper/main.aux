\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textit  {Left}: KV-cache hit rate vs.\ p95 TTFT on W2. Bottom-right is ideal (high cache, low latency). \texttt  {gorgo-static} and \texttt  {gorgo-hillclimb} achieve both; \texttt  {simple-session-affinity} achieves the highest cache hit rate but the worst p95 because it cannot rebalance load. \textit  {Right}: routing concentration (share of requests on the most-used replica). The dashed line marks uniform (33\%). GORGO variants concentrate moderately on cache-warm replicas without the pathological imbalance of \texttt  {simple-session-affinity}.}}{8}{figure.caption.16}\protected@file@percent }
\newlabel{fig:cache_concentration}{{5}{8}{\textit {Left}: KV-cache hit rate vs.\ p95 TTFT on W2. Bottom-right is ideal (high cache, low latency). \texttt {gorgo-static} and \texttt {gorgo-hillclimb} achieve both; \texttt {simple-session-affinity} achieves the highest cache hit rate but the worst p95 because it cannot rebalance load. \textit {Right}: routing concentration (share of requests on the most-used replica). The dashed line marks uniform (33\%). GORGO variants concentrate moderately on cache-warm replicas without the pathological imbalance of \texttt {simple-session-affinity}}{figure.caption.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces W2 TTFT broken out by percentile (sorted by W1 p95, worst at top). Gold outline marks the winner in each panel. \texttt  {gorgo-static} (frozen W1 weights) wins p50 and p95; \texttt  {gorgo-hillclimb} wins p99. \texttt  {simple-session-affinity} degrades sharply at the tail (4.92\,s p99).}}{8}{figure.caption.17}\protected@file@percent }
\newlabel{fig:percentiles}{{6}{8}{W2 TTFT broken out by percentile (sorted by W1 p95, worst at top). Gold outline marks the winner in each panel. \texttt {gorgo-static} (frozen W1 weights) wins p50 and p95; \texttt {gorgo-hillclimb} wins p99. \texttt {simple-session-affinity} degrades sharply at the tail (4.92\,s p99)}{figure.caption.17}{}}
