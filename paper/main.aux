\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces WildChat-4.8M replay: 30-minute window, $c{=}32$. TTFT in seconds. Bold is best in column. Compared to the GLM-5.1 results, GORGO variants are not competitive: \texttt  {gorgo-static} and \texttt  {gorgo-autotune} are the worst two policies on p95.}}{14}{table.caption.30}\protected@file@percent }
\newlabel{tab:wildchat}{{6}{14}{WildChat-4.8M replay: 30-minute window, $c{=}32$. TTFT in seconds. Bold is best in column. Compared to the GLM-5.1 results, GORGO variants are not competitive: \texttt {gorgo-static} and \texttt {gorgo-autotune} are the worst two policies on p95}{table.caption.30}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces WildChat-4.8M replay, per-percentile TTFT (p50/p95/p99) across the eight policies. GORGO variants (dark blues) are not competitive: \texttt  {gorgo-static} and \texttt  {gorgo-autotune} are the slowest two policies at the tail, and \texttt  {gorgo-hillclimb} sits mid-pack. The ranking inverts the GLM-5.1 result, consistent with the regime argument in \S  \ref {sec:characterization}.}}{15}{figure.caption.31}\protected@file@percent }
\newlabel{fig:ttft_bars_wildchat}{{7}{15}{WildChat-4.8M replay, per-percentile TTFT (p50/p95/p99) across the eight policies. GORGO variants (dark blues) are not competitive: \texttt {gorgo-static} and \texttt {gorgo-autotune} are the slowest two policies at the tail, and \texttt {gorgo-hillclimb} sits mid-pack. The ranking inverts the GLM-5.1 result, consistent with the regime argument in \S \ref {sec:characterization}}{figure.caption.31}{}}
