\@writefile{toc}{\contentsline {section}{\numberline {A}WildChat replay (regime-sensitivity control)}{12}{appendix.A}\protected@file@percent }
\newlabel{app:wildchat}{{A}{12}{WildChat replay (regime-sensitivity control)}{appendix.A}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces WildChat-4.8M replay: 30-minute window, $c{=}32$. TTFT in seconds. Bold is best in column. Compared to the GLM-5.1 results, GORGO variants are not competitive: \texttt  {gorgo-static} and \texttt  {gorgo-autotune} are the worst two policies on p95.}}{12}{table.caption.27}\protected@file@percent }
\newlabel{tab:wildchat}{{4}{12}{WildChat-4.8M replay: 30-minute window, $c{=}32$. TTFT in seconds. Bold is best in column. Compared to the GLM-5.1 results, GORGO variants are not competitive: \texttt {gorgo-static} and \texttt {gorgo-autotune} are the worst two policies on p95}{table.caption.27}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces WildChat-4.8M replay, per-percentile TTFT (p50/p95/p99) across the eight policies. GORGO variants (dark blues) are not competitive: \texttt  {gorgo-static} and \texttt  {gorgo-autotune} are the slowest two policies at the tail, and \texttt  {gorgo-hillclimb} sits mid-pack. The ranking inverts the GLM-5.1 result, consistent with the regime argument in \S  \ref {sec:characterization}.}}{13}{figure.caption.28}\protected@file@percent }
\newlabel{fig:ttft_bars_wildchat}{{5}{13}{WildChat-4.8M replay, per-percentile TTFT (p50/p95/p99) across the eight policies. GORGO variants (dark blues) are not competitive: \texttt {gorgo-static} and \texttt {gorgo-autotune} are the slowest two policies at the tail, and \texttt {gorgo-hillclimb} sits mid-pack. The ranking inverts the GLM-5.1 result, consistent with the regime argument in \S \ref {sec:characterization}}{figure.caption.28}{}}
