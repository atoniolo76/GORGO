\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Dataset comparison along axes that determine the routing-decision surface. Token counts use the same byte-pair tokenizer in all rows. Reuse percentages are token-weighted prefix-trie savings. LMSYS-Chat-1M does not expose a stable user identifier (only conversation IDs), so its intra-user reuse and per-user-counts are reported as ``---'' (treating each conversation as a separate user yields essentially zero intra-user reuse).}}{4}{table.caption.3}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{tab:datasets}{{1}{4}{Dataset comparison along axes that determine the routing-decision surface. Token counts use the same byte-pair tokenizer in all rows. Reuse percentages are token-weighted prefix-trie savings. LMSYS-Chat-1M does not expose a stable user identifier (only conversation IDs), so its intra-user reuse and per-user-counts are reported as ``---'' (treating each conversation as a separate user yields essentially zero intra-user reuse)}{table.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Three axes of dataset characterization. \textit  {Left}: average input tokens per request (log scale)---GLM-5.1 is 45$\times $ longer than LMSYS and 7$\times $ longer than WildChat. \textit  {Center}: requests per user (log scale)---82 on GLM-5.1 vs.\ 1.7 on WildChat vs.\ 1 on LMSYS. \textit  {Right}: prefix-reuse breakdown---GLM-5.1 reuse is dominated by intra-user repeat-conversation prefixes; WildChat reuse is dominated by cross-user structural similarity (shared system prompts, viral templates); LMSYS has no per-user signal at all.}}{4}{figure.caption.4}\protected@file@percent }
\newlabel{fig:dataset_comparison}{{1}{4}{Three axes of dataset characterization. \textit {Left}: average input tokens per request (log scale)---GLM-5.1 is 45$\times $ longer than LMSYS and 7$\times $ longer than WildChat. \textit {Center}: requests per user (log scale)---82 on GLM-5.1 vs.\ 1.7 on WildChat vs.\ 1 on LMSYS. \textit {Right}: prefix-reuse breakdown---GLM-5.1 reuse is dominated by intra-user repeat-conversation prefixes; WildChat reuse is dominated by cross-user structural similarity (shared system prompts, viral templates); LMSYS has no per-user signal at all}{figure.caption.4}{}}
